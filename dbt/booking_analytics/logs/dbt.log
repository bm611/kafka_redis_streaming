        max(event_timestamp) as last_booking_at
    from bookings
    group by hotel_name, country
)

select
    md5(cast(coalesce(cast(hotel_name as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as hotel_id,
    *
from hotel_stats
  );
  
